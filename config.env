# Cubs Game MQTT Service — non-secret configuration
# Populate a K8s ConfigMap from this file:
#   kubectl create configmap cubs-game-config --from-env-file=config.env
# Or reference it in a Deployment via envFrom: configMapRef.
# Secrets (MQTT_USERNAME, MQTT_PASSWORD) live in a separate K8s Secret.

# MQTT broker URL (scheme://host:port)
MQTT_BROKER_URL=mqtt://home-assistant.example.com:1883

# AWTRIX device name — used to build default topic names
AWTRIX_DEVICE=awtrix

# MQTT topic overrides (defaults derived from AWTRIX_DEVICE if left at defaults)
MQTT_TOPIC=awtrix/custom/cubs_game_next
MQTT_STANDINGS_TOPIC=awtrix/custom/cubs_standings

# MQTT client settings
MQTT_CLIENT_ID=cubs-game-service
MQTT_RETAIN=false

# AWTRIX icon IDs
MQTT_ICON=40217
MQTT_WIN_ICON=74405

# Display settings
MQTT_DURATION=5
MQTT_DURATION_LIVE=7
MQTT_SCROLL=true
MQTT_COLOR=#002C5F

# Poll intervals (seconds)
POLL_NO_GAMES=14400
POLL_UPCOMING=900
POLL_TODAY=300
POLL_LIVE=30
POLL_FINAL=300
